import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LogisticRegression
from sklearn.svm import SVC
from sklearn.metrics import (
    matthews_corrcoef, 
    average_precision_score, 
    recall_score, 
    classification_report
)

def load_and_preprocess(filepath):
    """Loads the cleaned CSVs and applies standard scaling."""
    df = pd.read_csv(filepath)
    X = df.drop('target', axis=1)
    y = df['target']
    
    # Stratified split ensures minority class is represented in both sets
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.3, random_state=42, stratify=y
    )
    
    scaler = StandardScaler()
    X_train = scaler.fit_transform(X_train)
    X_test = scaler.transform(X_test)
    
    return X_train, X_test, y_train, y_test

def evaluate_model(model, X_test, y_test, model_name):
    """Calculates the specific metrics required for the EC503 project."""
    preds = model.predict(X_test)
    # probability=True is needed for SVC to get scores for AUPRC
    probs = model.predict_proba(X_test)[:, 1] 
    
    mcc = matthews_corrcoef(y_test, preds)
    auprc = average_precision_score(y_test, probs)
    sensitivity = recall_score(y_test, preds)
    
    print(f"\n--- Results for {model_name} ---")
    print(f"Sensitivity (Recall): {sensitivity:.4f}")
    print(f"MCC:                  {mcc:.4f}")
    print(f"AUPRC:                {auprc:.4f}")
    return {"mcc": mcc, "auprc": auprc, "recall": sensitivity}

def run_baselines(dataset_path, dataset_name):
    print(f"\n{'='*20} DATASET: {dataset_name} {'='*20}")
    X_train, X_test, y_train, y_test = load_and_preprocess(dataset_path)

    # 1. Logistic Regression Baseline
    lr = LogisticRegression(max_iter=1000)
    lr.fit(X_train, y_train)
    evaluate_model(lr, X_test, y_test, "Logistic Regression")

    # 2. Standard SVM Baseline
    svm_std = SVC(kernel='rbf', probability=True)
    svm_std.fit(X_train, y_train)
    evaluate_model(svm_std, X_test, y_test, "Standard SVM")

    # 3. Cost-Sensitive SVM (The 'Improved' Baseline)
    svm_cost = SVC(kernel='rbf', class_weight='balanced', probability=True)
    svm_cost.fit(X_train, y_train)
    evaluate_model(svm_cost, X_test, y_test, "Cost-Sensitive SVM")

if __name__ == "__main__":
    # Ensure these CSV files are in the same folder as this script
    run_baselines('breast_cancer_clean.csv', "Breast Cancer Wisconsin")
    run_baselines('spect_heart_clean.csv', "SPECT Heart")
