# 2. Setup the Pipeline
# We use a pipeline to ensure SMOTE is only applied to training data during CV
def build_ensemble_model():
    # Base SVM with Cost-Sensitive Learning (class_weight='balanced')
    base_svm = SVC(kernel='rbf', probability=True, class_weight='balanced')
    
    # Ensemble: Bagging with the SVMs
    ensemble = BaggingClassifier(base_estimator=base_svm, n_estimators=10, random_state=42)
    
    # Integration with SMOTE
    model = Pipeline([
        ('smt', SMOTE(random_state=42)),
        ('clf', ensemble)
    ])
    return model

# 3. Evaluation Function
def evaluate_model(model, X_test, y_test, name):
    preds = model.predict(X_test)
    probs = model.predict_proba(X_test)[:, 1]
    
    print(f"--- {name} Results ---")
    print(f"MCC: {matthews_corrcoef(y_test, preds):.4f}")
    print(f"AUPRC: {average_precision_score(y_test, probs):.4f}")
    print(classification_report(y_test, preds))

